@using HeroesProfile.Core.CQRS.Queries
@using HeroesProfile.Core.CQRS.Commands
@using HeroesProfile.Core.Models
@using MediatR
@using ReactiveUI.Blazor

@page "/settings"
@inherits ReactiveComponentBase<SettingsViewModel>

<PageProgress Visible=@(ViewModel == null) />

@if (ViewModel.Form != null)
{
    <Row>
        <Column ColumnSize="ColumnSize.IsHalf">
            <Card Margin="Margin.Is4.OnY">
                <CardHeader>
                    <CardTitle>Twitch Authentication</CardTitle>
                </CardHeader>
                <CardBody>
                    <Validations Mode=ValidationMode.Auto ValidateOnLoad=false>

                        <Validation Validator=@ValidationRule.IsNotEmpty>
                            <Field Horizontal="true">
                                <FieldLabel ColumnSize="ColumnSize.Is3">Broadcaster Id</FieldLabel>
                                <FieldBody ColumnSize="ColumnSize.Is6">
                                    <TextEdit Placeholder="Broadcaster Id" Text=@ViewModel.Form.BroadcasterId>
                                        <ValidationNone>Please enter your Twitch Id</ValidationNone>
                                        <ValidationSuccess>We found your account.</ValidationSuccess>
                                        <ValidationError>Could not find your account.</ValidationError>
                                    </TextEdit>
                                </FieldBody>
                            </Field>
                        </Validation>

                        <Validation Validator=@ValidationRule.IsNotEmpty>
                            <Field Horizontal="true">
                                <FieldLabel ColumnSize="ColumnSize.Is3">Client Id</FieldLabel>
                                <FieldBody ColumnSize="ColumnSize.Is6">
                                    <TextEdit Placeholder="Twitch Client Id" Text=@ViewModel.Form.TwitchClientId />
                                </FieldBody>
                            </Field>
                        </Validation>

                        <Validation Validator=@ValidationRule.IsNotEmpty>
                            <Field Horizontal="true">
                                <FieldLabel ColumnSize="ColumnSize.Is3">Access Token</FieldLabel>
                                <FieldBody ColumnSize="ColumnSize.Is6">
                                    <TextEdit Placeholder="Twitch Access Token" Text=@ViewModel.Form.TwitchAccessToken />
                                </FieldBody>
                            </Field>
                        </Validation>
                    </Validations>
                </CardBody>
            </Card>
        </Column>
        <Column ColumnSize="ColumnSize.IsHalf">
            <Card Margin="Margin.Is4.OnY">
                <CardHeader>
                    <CardTitle>Heroes Profile Authentication</CardTitle>
                </CardHeader>
                <CardBody>
                    <Validations Mode=ValidationMode.Auto ValidateOnLoad=false>

                        <Validation Validator=@ValidationRule.IsNotEmpty>
                            <Field Horizontal="true">
                                <FieldLabel ColumnSize="ColumnSize.Is3">Email</FieldLabel>
                                <FieldBody ColumnSize="ColumnSize.Is6">
                                    <TextEdit Placeholder="" Text=@ViewModel.Form.HeroesProfileApiEmail>
                                        <Feedback>
                                            <ValidationError />
                                        </Feedback>
                                    </TextEdit>
                                </FieldBody>
                            </Field>
                        </Validation>

                        <Validation Validator=@ViewModel.ValidateUserId>
                            <Field Horizontal="true">
                                <FieldLabel ColumnSize="ColumnSize.Is3">User Id</FieldLabel>
                                <FieldBody ColumnSize="ColumnSize.Is6">
                                    <TextEdit Placeholder="" Text=@ViewModel.Form.HeroesProfileUserId>
                                        <Feedback>
                                            <ValidationError />
                                        </Feedback>
                                    </TextEdit>
                                </FieldBody>
                            </Field>
                        </Validation>

                        <Validation Validator=@ValidationRule.IsNotEmpty>
                            <Field Horizontal="true">
                                <FieldLabel ColumnSize="ColumnSize.Is3">Twitch Key</FieldLabel>
                                <FieldBody ColumnSize="ColumnSize.Is6">
                                    <TextEdit Text=@ViewModel.Form.HeroesProfileTwitchKey>
                                        <Feedback>
                                            <ValidationError />
                                        </Feedback>
                                    </TextEdit>
                                </FieldBody>
                            </Field>
                        </Validation>
                    </Validations>
                </CardBody>
            </Card>
        </Column>
    </Row>

    <Row>
        <Column ColumnSize=ColumnSize.IsHalf>
            <Card Margin="Margin.Is4.OnY">
                <CardHeader>
                    <CardTitle>Enable or Disable features</CardTitle>
                </CardHeader>
                <CardBody>
                    <Validations Mode=ValidationMode.Auto ValidateOnLoad=false>

                        <Field Horizontal="true">
                                <FieldLabel ColumnSize="ColumnSize.Is4">Twitch Talents Extension</FieldLabel>
                                <FieldBody ColumnSize="ColumnSize.Is6">
                                    <Switch TValue="bool" @bind-Checked=@ViewModel.Form.EnableTwitchExtension />
                                </FieldBody>
                            </Field>

                        <Field Horizontal="true">
                                <FieldLabel ColumnSize="ColumnSize.Is4">Twitch Auto Predictions</FieldLabel>
                                <FieldBody ColumnSize="ColumnSize.Is6">
                                    <Switch TValue="bool" @bind-Checked=@ViewModel.Form.EnablePredictions />
                                </FieldBody>
                            </Field>

                        <Validation Validator=@ViewModel.ValidateBattleTags>
                            <Field Horizontal="true">
                                <FieldLabel ColumnSize="ColumnSize.Is4">BattleTags for Auto Predictions</FieldLabel>
                                <FieldBody ColumnSize="ColumnSize.Is6">
                                    <MemoEdit Rows="5" @bind-Text="ViewModel.Form.BattleTags">
                                        <Feedback>
                                             <ValidationNone>BattleTags should be seperated by a space or new line</ValidationNone>
                                             <ValidationSuccess>Format is valid.</ValidationSuccess>
                                             <ValidationError>Invalid format.</ValidationError>
                                        </Feedback>
                                    </MemoEdit>
                                </FieldBody>
                            </Field>
                        </Validation>

                        <!-- Could be embedded into the Desktop App under seperate menu items or as part of Session page as Tabs with embedded WebView2 Components -->
                         <Field Horizontal="true">
                                <FieldLabel ColumnSize="ColumnSize.IsFull.OnTablet.Is4.OnDesktop">Generate Post match Link</FieldLabel>
                                <FieldBody ColumnSize="ColumnSize.IsFull.OnTablet.Is6.OnDesktop">
                                    <Switch TValue="bool" @bind-Checked=@ViewModel.Form.EnablePostMatch  />
                                </FieldBody>
                            </Field>

                        <!-- Could be embedded into the Desktop App under seperate menu items or as part of Session page as Tabs with embedded WebView2 Components -->
                         <Field Horizontal="true">
                                <FieldLabel ColumnSize="ColumnSize.Is4">Generate Pre match Link</FieldLabel>
                                <FieldBody ColumnSize="ColumnSize.Is6">
                                    <Switch TValue="bool" @bind-Checked=@ViewModel.Form.EnablePreMatch />
                                </FieldBody>
                            </Field>

                        <!-- We should probably do this automatically, why keep a massive ever-growing list? -->
                        <Field Horizontal="true">
                                <FieldLabel ColumnSize="ColumnSize.Is4">Purge Deleted Replays</FieldLabel>
                                <FieldBody ColumnSize="ColumnSize.Is6">
                                    <Switch TValue="bool" />
                                </FieldBody>
                            </Field>

                    </Validations>
                </CardBody>
            </Card>
        </Column>
    </Row>


    <Row>
        <Column>
            <Field>
                <Button Color="Color.Primary" Type="ButtonType.Button" PreventDefaultOnSubmit="true" Clicked=@ViewModel.SaveAsync>Save Changes</Button>
            </Field>
        </Column>
    </Row>
}

@code {

    [Inject]
    public SettingsViewModel SettingsViewModel
    {
        get => ViewModel;
        set => ViewModel = value;
    }

    protected override async Task OnInitializedAsync()
    {
        await ViewModel.LoadAsync();
        StateHasChanged();
    }
}