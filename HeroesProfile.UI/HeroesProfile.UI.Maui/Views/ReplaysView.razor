@page "/"

@using HeroesProfile.UI.Maui.ViewModels
@using ReactiveUI
@using ReactiveUI.Blazor
@using System.Reactive.Threading.Tasks
@using System.Threading

@inherits ReactiveComponentBase<ReplaysViewModel>

<PageProgress Visible=@(ViewModel == null) />

@if (ViewModel.StoredReplays != null)
{
    <Row>
        <Column>
            <DataGrid TItem=ReplaysViewModel.GridItem
                  Data=@ViewModel.StoredReplays
                  Filterable=true
                  ShowPager=true
                  PageSize=10
                  Editable=false
                  FilterMethod=DataGridFilterMethod.StartsWith
                  @bind-SelectedRow="@ViewModel.SelectedRow">

                <DataGridCommandColumn TItem="ReplaysViewModel.GridItem" />
                <DataGridColumn TItem="ReplaysViewModel.GridItem" Field="@nameof(ReplaysViewModel.GridItem.Path)" Caption="Path" />
                <DataGridColumn TItem="ReplaysViewModel.GridItem" Field="@nameof(ReplaysViewModel.GridItem.Created)" Caption="Created" />
                <DataGridColumn TItem="ReplaysViewModel.GridItem" Field="@nameof(ReplaysViewModel.GridItem.Updated)" Caption="Updated" />
                <DataGridColumn TItem="ReplaysViewModel.GridItem" Field="@nameof(ReplaysViewModel.GridItem.Deleted)" Caption="Deleted" />
                <DataGridColumn TItem="ReplaysViewModel.GridItem" Field="@nameof(ReplaysViewModel.GridItem.Fingerprint)" Caption="Fingerprint" />
                <DataGridColumn TItem="ReplaysViewModel.GridItem" Field="@nameof(ReplaysViewModel.GridItem.ParseResult)" Caption="Parse Result">
                    <DisplayTemplate>
                        <Badge Color=context.ParseResultColor>@context.ParseResult</Badge>
                    </DisplayTemplate>
                </DataGridColumn>
                <DataGridColumn TItem="ReplaysViewModel.GridItem" Field="@nameof(ReplaysViewModel.GridItem.UploadStatus)" Caption="Upload Status">
                    <DisplayTemplate>
                        <Badge Color=context.UploadStatusColor>@context.UploadStatus</Badge>
                    </DisplayTemplate>
                </DataGridColumn>
                <DataGridColumn TItem="ReplaysViewModel.GridItem" Field="@nameof(ReplaysViewModel.GridItem.ProcessStatus)" Caption="Process Status">
                    <DisplayTemplate>
                        <Badge Color=context.ProcessStatusColor>@context.ProcessStatus</Badge>
                    </DisplayTemplate>
                </DataGridColumn>
                <!-- TODO: Add Button to Open / Navigate to Heroes Profile Replay Page -->

        </DataGrid>
        </Column>
    </Row>
}

@code {

    [Inject]
    public ReplaysViewModel ReplaysViewModel
    {
        get => ViewModel;
        set => ViewModel = value;
    }

    protected async override Task OnInitializedAsync() => await ViewModel.LoadAsync(CancellationToken.None);

}