@page "/replays"
@page "/"

@using MediatR
@using HeroesProfile.Core.CQRS
@using HeroesProfile.Core.CQRS.Queries
@using HeroesProfile.Core.Models

<PageProgress Visible=@(replays == null) />

<Row>
    <Column>
        <Alert Color=Color.Info @bind-Visible="@visible">
            <AlertDescription>This view shows scanned replays and their status.</AlertDescription>
            <CloseButton />
        </Alert>
    </Column>
</Row>

<Row>
    <Column>
        <Heading Size=HeadingSize.Is2>Replays</Heading>
    </Column>
</Row>


@if (replays != null)
{
            <Row>
                <Column>
                     <DataGrid TItem=DataGridItem Data=@replays Filterable=true ShowPager=true PageSize=10 Editable=false FilterMethod=DataGridFilterMethod.StartsWith @bind-SelectedRow=@selected>
                        <DataGridCommandColumn TItem="DataGridItem" />
                        <DataGridColumn TItem="DataGridItem" Field="@nameof(DataGridItem.Path)" Caption="Path" Sortable="true" />
                        <DataGridColumn TItem="DataGridItem" Field="@nameof(DataGridItem.Created)" Caption="Date created" />
                        <DataGridColumn TItem="DataGridItem" Field="@nameof(DataGridItem.Deleted)" Caption="Deleted" />
                        <DataGridColumn TItem="DataGridItem" Field="@nameof(DataGridItem.Fingerprint)" Caption="Fingerprint" />
                        <DataGridColumn TItem="DataGridItem" Field="@nameof(DataGridItem.ParseResult)" Caption="Parse Result" />
                        <DataGridColumn TItem="DataGridItem" Field="@nameof(DataGridItem.UploadStatus)" Caption="Upload Status" />
                        <DataGridColumn TItem="DataGridItem" Field="@nameof(DataGridItem.ProcessStatus)" Caption="Process Status" />
                </DataGrid>
                </Column>
            </Row>
}

@code {

    // Custom View of Data
    public class DataGridItem
    {
        public StoredReplay Item { get; set; }

        public DateTime Created => Item.Created;
        public string Path => System.IO.Path.GetFileName(Item.Path);
        public bool Deleted => !System.IO.File.Exists(Item.Path);
        public string Fingerprint => Item.Fingerprint;
        public ParseResult ParseResult => Item.ParseResult;
        public UploadStatus UploadStatus => Item.UploadStatus;
        public ProcessStatus ProcessStatus => Item.ProcessStatus;
    }

    [Inject]
    private IMediator Mediator { get; set; }

    private List<DataGridItem> replays;
    private DataGridItem selected;
    private bool visible = true;

    protected override async Task OnInitializedAsync()
    {
        GetReplays.Response response = await Mediator.Send(new GetReplays.Query(new List<GetReplays.Filter>()));

        if (response.Replays.Any())
        {
            replays = response.Replays.Select(x => new DataGridItem { Item = x }).ToList();
        }

        StateHasChanged();
    }
}