@page "/session"
@using ReactiveUI.Blazor
@using System.Reactive.Threading.Tasks
@using System.Text.Json
@inherits ReactiveComponentBase<SessionViewModel>

<Row>
    <Column>
        <Heading Size=HeadingSize.Is2>Session</Heading>
    </Column>
</Row>

<PageProgress Visible="@(ViewModel == null)" />

@if (ViewModel != null)
{
    <!-- Show the state progression from BattleLobby -> StormSave -> StormReplay -->
    <!-- https://rcbootstrapdemo.blazorise.com/tests/steps -->

    <Row>
        <Column>
            <Row>
                    <Heading Size=HeadingSize.Is4>BattleLobby</Heading>
                  <pre>
                    @ViewModel.BattleLobbyJson
                  </pre>
            </Row>
            <Row>
                <Heading Size=HeadingSize.Is4>StormSave</Heading>
                 <pre>
                      @ViewModel.StormSaveJson
                 </pre>
            </Row>
        </Column>
        <Column>
            <Row>
                <Heading Size=HeadingSize.Is4>StormReplay</Heading>
                 <pre>
                      @ViewModel.StormReplayJson
                 </pre>
            </Row>
            <Row>
                <pre>
                    @ViewModel.TwitchJson
                </pre>
            </Row>
        </Column>
    </Row>
}

@code {

    [Inject]
    public SessionViewModel SessionViewModel
    {
        get => ViewModel;
        set => ViewModel = value;
    }

    protected async override Task OnInitializedAsync()
    {
        await SessionViewModel.LoadSessionAsync();
    }
}
